            firesignal(LocalPlayer.PlayerGui.DialogueGui.Frame.Options.Option1.TextButton.MouseButton1Click)
            repeat firesignal(LocalPlayer.PlayerGui.DialogueGui.Frame.ClickContinue.MouseButton1Click) task.wait(0.05) until LocalPlayer.PlayerGui.DialogueGui.Frame.Options:FindFirstChild("Option1")
            if LocalPlayer.PlayerGui.DialogueGui.Frame.Options:FindFirstChild("Option1") then
                firesignal(LocalPlayer.PlayerGui.DialogueGui.Frame.Options.Option1.TextButton.MouseButton1Click)
            end
            repeat firesignal(LocalPlayer.PlayerGui.DialogueGui.Frame.ClickContinue.MouseButton1Click) task.wait(0.05) until LocalPlayer.PlayerGui.DialogueGui.Frame.Options:FindFirstChild("Option1")
            if LocalPlayer.PlayerGui.DialogueGui.Frame.Options:FindFirstChild("Option1") then
                firesignal(LocalPlayer.PlayerGui.DialogueGui.Frame.Options.Option1.TextButton.MouseButton1Click)
            end
            task.wait(10)
            autoStory()
        else
