local function SH_TPReturner()
    local url = "https://games.roblox.com/v1/games/" .. SH_PlaceID .. "/servers/Public?sortOrder=Asc&limit=100"
    if SH_foundAnything ~= "" then url = url .. "&cursor=" .. SH_foundAnything end
    local Site = HttpService:JSONDecode(game:HttpGet(url))
    if Site.nextPageCursor and Site.nextPageCursor ~= "null" then
        SH_foundAnything = Site.nextPageCursor
    end
    local num = 0
    for _, v in pairs(Site.data) do
        local Possible = true
        local ID = tostring(v.id)
        if tonumber(v.maxPlayers) > tonumber(v.playing) then
            for _, Existing in pairs(SH_AllIDs) do
                if num ~= 0 then
                    if ID == tostring(Existing) then Possible = false end
                else
                    if tonumber(SH_actualHour) ~= tonumber(Existing) then
                        pcall(function()
                            delfile("NotSameServers.json")
                            SH_AllIDs = {}
                            table.insert(SH_AllIDs, SH_actualHour)
                        end)
                    end
                end
                num += 1
            end
            if Possible then
                table.insert(SH_AllIDs, ID)
                task.wait()
                pcall(function()
                    writefile("NotSameServers.json", HttpService:JSONEncode(SH_AllIDs))
                    task.wait()
                    TeleportService:TeleportToPlaceInstance(SH_PlaceID, ID, Players.LocalPlayer)
                end)
                task.wait(4)
            end
        end
    end
end

local function ServerHop()
