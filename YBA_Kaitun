-- ##### Webhook #####
local function SendWebhook(reason)
    local lp   = Players.LocalPlayer
    local name = lp.DisplayName or "Unknown"
    local uid  = lp.UserId or 0
    local profileUrl = "https://www.roblox.com/users/" .. uid .. "/profile"
    local avatarUrl  = "https://cdn.discordapp.com/embed/avatars/4.png"
    local ok, result = pcall(function()
        return Players:GetUserThumbnailAsync(uid, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
    end)
    if ok and result and type(result) == "string" then
        avatarUrl = "https://bloxcdn.dev/image/" .. result:gsub("https://", "")
    end
    local t = os.date("!*t", os.time())
    local embed = {
        title       = "Player Information",
        description = reason,
        color       = 3447003,
        footer      = { text = "Job ID: " .. tostring(game.JobId or "N/A") },
        author      = { name = name .. " (ID: " .. uid .. ")", url = profileUrl, icon_url = avatarUrl },
        thumbnail   = { url = avatarUrl },
        fields = {
            { name = "Display Name", value = name,          inline = true  },
            { name = "User ID",      value = tostring(uid), inline = true  },
            { name = "Profile Link", value = profileUrl,    inline = false },
        },
        timestamp = string.format("%d-%02d-%02dT%02d:%02d:%02dZ", t.year, t.month, t.day, t.hour, t.min, t.sec),
    }
    local encodeOk, body = pcall(function()
        return HttpService:JSONEncode({ content = reason, embeds = { embed } })
    end)
    if not encodeOk then return end
    local opts = { Url = getgenv().WebhookURL, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = body }
    pcall(function()
        if syn and syn.request then syn.request(opts)
        elseif http_request then http_request(opts) end
    end)
end

